{
  "version": 1,
  "weapon": "charge_cannon",
  "magazineSize": 6,
  "initialState": "idle",
  "actionSequences": {
    "charge_start": [
      {
        "type": "play_sound",
        "sound": "assets/audio/weapons/charge_cannon/charge_start.wav"
      }
    ],
    "charge_loop": [
      {
        "type": "play_sound",
        "sound": "assets/audio/weapons/charge_cannon/charge_loop.wav",
        "loop": true
      }
    ],
    "charge_fire": [
      {
        "type": "stop_sound"
      },
      {
        "type": "play_sound_random",
        "sounds": [
          "assets/audio/weapons/charge_cannon/fire_0.wav",
          "assets/audio/weapons/charge_cannon/fire_1.wav"
        ]
      },
      {
        "type": "emit_shot"
      },
      {
        "type": "flash_muzzle"
      },
      {
        "type": "consume_ammo",
        "amount": 1
      }
    ],
    "charge_cancel": [
      {
        "type": "stop_sound"
      },
      {
        "type": "play_sound",
        "sound": "assets/audio/weapons/charge_cannon/cancel.wav"
      }
    ],
    "charge_complete_fx": [
      {
        "type": "play_sound",
        "sound": "assets/audio/weapons/charge_cannon/charged.wav"
      }
    ],
    "reload_fx": [
      {
        "type": "play_sound",
        "sound": "assets/audio/weapons/charge_cannon/reload.wav"
      },
      {
        "type": "set_light",
        "pattern": {
          "mode": "pulse",
          "color": [
            0,
            255,
            80
          ],
          "brightness": 180,
          "intervalMs": 180
        }
      }
    ]
  },
  "states": {
    "idle": {
      "onEnter": [
        {
          "type": "set_light",
          "pattern": {
            "mode": "solid",
            "color": [
              0,
              120,
              255
            ],
            "brightness": 120
          }
        }
      ],
      "onExit": [],
      "transitions": [
        {
          "event": "trigger_pressed",
          "target": "charging",
          "actions": [
            {
              "type": "run_sequence",
              "name": "charge_start"
            },
            {
              "type": "run_sequence",
              "name": "charge_loop"
            },
            {
              "type": "schedule_event",
              "event": "charge_complete",
              "delayMs": 800
            }
          ]
        },
        {
          "event": "ammo_empty",
          "target": "empty"
        },
        {
          "event": "reload",
          "target": "reloading",
          "actions": [
            {
              "type": "run_sequence",
              "name": "reload_fx"
            }
          ]
        }
      ]
    },
    "charging": {
      "onEnter": [
        {
          "type": "set_light",
          "pattern": {
            "mode": "pulse",
            "color": [
              255,
              160,
              60
            ],
            "brightness": 180,
            "intervalMs": 120
          }
        }
      ],
      "onExit": [],
      "transitions": [
        {
          "event": "charge_complete",
          "target": "charged",
          "actions": [
            {
              "type": "run_sequence",
              "name": "charge_complete_fx"
            }
          ]
        },
        {
          "event": "trigger_released",
          "target": "idle",
          "actions": [
            {
              "type": "run_sequence",
              "name": "charge_cancel"
            }
          ]
        },
        {
          "event": "reload",
          "target": "reloading",
          "actions": [
            {
              "type": "stop_sound"
            },
            {
              "type": "run_sequence",
              "name": "reload_fx"
            }
          ]
        }
      ]
    },
    "charged": {
      "onEnter": [
        {
          "type": "set_light",
          "pattern": {
            "mode": "solid",
            "color": [
              255,
              160,
              60
            ],
            "brightness": 255
          }
        }
      ],
      "onExit": [],
      "transitions": [
        {
          "event": "trigger_released",
          "target": "idle",
          "actions": [
            {
              "type": "run_sequence",
              "name": "charge_fire"
            }
          ]
        },
        {
          "event": "reload",
          "target": "reloading",
          "actions": [
            {
              "type": "stop_sound"
            },
            {
              "type": "run_sequence",
              "name": "reload_fx"
            }
          ]
        }
      ]
    },
    "empty": {
      "onEnter": [
        {
          "type": "set_light",
          "pattern": {
            "mode": "pulse",
            "color": [
              255,
              0,
              0
            ],
            "brightness": 180,
            "intervalMs": 220
          }
        }
      ],
      "onExit": [],
      "transitions": [
        {
          "event": "reload_complete",
          "target": "idle"
        },
        {
          "event": "reload",
          "target": "reloading",
          "actions": [
            {
              "type": "run_sequence",
              "name": "reload_fx"
            }
          ]
        }
      ]
    },
    "reloading": {
      "onEnter": [],
      "onExit": [],
      "transitions": [
        {
          "event": "reload_complete",
          "target": "idle"
        }
      ]
    }
  }
}